# Roseberry Storage Website — Environment Variables
# Copy this file to .env and fill in the values

# Server-only — Railway Postgres (same DB as assistant in Phase 1)
DATABASE_URL=postgresql://user:password@host:port/railway

# Server-only — signs site_token session cookie for blog/site admin
# Generate with: openssl rand -hex 32
SITE_JWT_SECRET=

# Shared secret for assistant → website internal webhooks (optional; falls back to API_KEY)
INTERNAL_API_KEY=

# Google Search Console (optional — embedded SEO analytics in /admin/website)
GOOGLE_SERVICE_ACCOUNT_JSON=
GSC_SITE_URL=

# URL of the Roseberry Assistant backend API
# Local development: http://localhost:3001
# Production: https://your-backend-domain.com
NUXT_PUBLIC_API_BASE=http://localhost:3001

# Your client ID from the Roseberry Assistant platform.
# Obtain this after registering via POST /api/clients (platform admin).
# This is a non-secret public identifier used to scope API requests.
NUXT_PUBLIC_CLIENT_ID=your-client-uuid-here

# Public site URL (used for SEO canonical URLs and sitemaps)
NUXT_PUBLIC_SITE_URL=https://www.roseberrycontainers.com

# Plausible Analytics domain (optional — e.g. roseberrycontainers.com)
NUXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Trustpilot TrustBox widget configuration.
# Get your Business Unit ID from: https://businessapp.b2b.trustpilot.com/#/integrations/trustbox
# Leave blank to show a static "leave a review" CTA instead.
NUXT_PUBLIC_TRUSTPILOT_BUSINESS_UNIT_ID=6a06021910ff31f733861f99
NUXT_PUBLIC_TRUSTPILOT_DOMAIN=roseberrycontainers.com
