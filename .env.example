# Roseberry Storage Website — Environment Variables
# Copy this file to .env and fill in the values

# URL of the Roseberry Assistant backend API
# Local development: http://localhost:3001
# Production: https://your-backend-domain.com
NUXT_PUBLIC_API_BASE=http://localhost:3001

# Your client ID from the Roseberry Assistant platform.
# Obtain this after registering via POST /api/clients (platform admin).
# This is a non-secret public identifier used to scope API requests.
NUXT_PUBLIC_CLIENT_ID=your-client-uuid-here
